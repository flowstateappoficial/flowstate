# ── Flowstate — Variáveis de ambiente ──
# Copia este ficheiro para .env.local e preenche os valores.
# O Vite só lê variáveis que comecem por VITE_.

# Supabase (já hardcoded em constants.js, mas pode migrar para env vars)
# VITE_SUPABASE_URL=https://XXXXX.supabase.co
# VITE_SUPABASE_ANON_KEY=sb_publishable_XXXXX

# Stripe
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_XXXXX

# Beta mode — quando true, todos os utilizadores logados têm plano "max".
# Remover ou pôr a false quando abrirmos ao público.
VITE_BETA_MODE=true

# Service Worker — forçar registo mesmo em dev (normalmente só corre em prod).
# VITE_ENABLE_SW=1
